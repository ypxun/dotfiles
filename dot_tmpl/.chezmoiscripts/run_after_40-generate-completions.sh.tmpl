#!/bin/bash
set -eufo pipefail

echo "📝 [Post-Apply] 正在检查和更新命令补全环境..."

# 统一的 Zsh 补全存放目录
ZSH_COMP_DIR="$HOME/.local/share/zsh/completions"
mkdir -p "$ZSH_COMP_DIR"

generate_completion() {
    local cmd_name="$1"
    # 文件名必须以 _ 开头，例如 _hermes
    local comp_file="$ZSH_COMP_DIR/_${cmd_name}"
    shift 1
    local gen_cmd=("$@")

    local bin_path
    if ! bin_path="$(command -v "$cmd_name" 2>/dev/null)"; then
        echo "  ⏭️  [$cmd_name] 未安装，跳过。"
        return 0
    fi

    if [ ! -f "$comp_file" ] || [ "$bin_path" -nt "$comp_file" ]; then
        echo "  ✨ [$cmd_name] 生成 Zsh 补全..."
        "${gen_cmd[@]}" > "$comp_file"
    else
        echo "  ✅ [$cmd_name] 补全已是最新的。"
    fi
}

generate_completion "hermes" hermes completion zsh
generate_completion "openclaw" openclaw completion -s zsh

echo "✨ 检查完毕！"