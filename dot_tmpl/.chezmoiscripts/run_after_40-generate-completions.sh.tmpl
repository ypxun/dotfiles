#!/bin/bash
set -eufo pipefail

echo "📝 [Post-Apply] 正在检查和更新命令补全环境..."

# ==============================================================================
# 核心生成函数
# 参数 1: 命令名称 (如 hermes)
# 参数 2: 补全文件存放的绝对路径
# 参数 3及以后: 生成命令 (如 hermes completion zsh)
# ==============================================================================
generate_completion() {
    local cmd_name="$1"
    local comp_file="$2"
    shift 2
    local gen_cmd=("$@")

    local bin_path
    if ! bin_path="$(command -v "$cmd_name" 2>/dev/null)"; then
        echo "  ⏭️  [$cmd_name] 未安装，跳过。"
        return 0
    fi

    if [ ! -f "$comp_file" ] || [ "$bin_path" -nt "$comp_file" ]; then
        echo "  ✨ [$cmd_name] 生成 Zsh 补全..."
        mkdir -p "$(dirname "$comp_file")"
        "${gen_cmd[@]}" > "$comp_file"
    else
        echo "  ✅ [$cmd_name] 补全已是最新的。"
    fi
}

# ------------------------------------------------------------------------------
# 1. Hermes: 乖孩子，放进统一的 fpath 目录，享受懒加载
# ------------------------------------------------------------------------------
ZSH_COMP_DIR="$HOME/.local/share/zsh/completions"
generate_completion "hermes" "$ZSH_COMP_DIR/_hermes" hermes completion zsh

# ------------------------------------------------------------------------------
# 2. OpenClaw: 熊孩子 (Cobra 框架 Bug)，放进私有目录，稍后在 zshrc 中强制 source
# ------------------------------------------------------------------------------
generate_completion "openclaw" "$HOME/.openclaw/completions/openclaw.zsh" openclaw completion -s zsh

# ------------------------------------------------------------------------------
# 3. [新增] Micromamba: 它是环境钩子 (包含补全和包装函数)，生成静态文件以供 Source
# ------------------------------------------------------------------------------
MAMBA_BIN="$(command -v micromamba 2>/dev/null || command -v mamba 2>/dev/null || true)"
if [ -n "$MAMBA_BIN" ]; then
    MAMBA_HOOK="$HOME/.mamba_hook.zsh"
    # 判断逻辑跟补全一样：没文件，或者二进制文件更新了，就重新生成
    if [ ! -f "$MAMBA_HOOK" ] || [ "$MAMBA_BIN" -nt "$MAMBA_HOOK" ]; then
        echo "  ✨ [Micromamba] 发现新版本，生成静态 Shell Hook..."
        "$MAMBA_BIN" shell hook --shell zsh --root-prefix "$HOME/mamba" > "$MAMBA_HOOK"
    else
        echo "  ✅ [Micromamba] 静态 Hook 已是最新的。"
    fi
else
    echo "  ⏭️  [Micromamba] 未安装，跳过。"
fi


echo "✨ 检查完毕！"