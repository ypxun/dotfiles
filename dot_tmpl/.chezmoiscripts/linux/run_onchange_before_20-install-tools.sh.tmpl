#!/bin/bash
set -eufo pipefail

{{ $sudo := "sudo " -}}
{{- if eq .chezmoi.username "root" -}}
    {{- $sudo = "" -}}
{{- end -}}

echo "🛠️  [2/3] 检查第三方生产力工具..."

# 1. [Eza] Debian/Ubuntu 专用 (使用第三方源获取最新版)
# 注意：script-10 中已特意跳过 eza 安装
{{ if eq .osid "linux-debian" "linux-ubuntu" "linux-linuxmint" -}}
if ! command -v eza &> /dev/null; then
    echo "✨ 配置 Eza 第三方源..."
    {{ $sudo }}mkdir -p /etc/apt/keyrings
    wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc | {{ $sudo }}gpg --dearmor -o /etc/apt/keyrings/gierrt.gpg
    echo "deb [signed-by=/etc/apt/keyrings/gierrt.gpg] http://deb.gierrt.me/debian stable main" | {{ $sudo }}tee /etc/apt/sources.list.d/gierrt.list
    {{ $sudo }}apt update && {{ $sudo }}apt install -y eza
else
    echo "  ✅ Eza 已安装。"
fi
{{- end }}

# 2. [Micromamba & uv] 仅在非 Headless 环境 (含 WSL) 安装
{{ if not .headless -}}

# [Micromamba] 官方二进制
if ! command -v micromamba &> /dev/null; then
    echo "🐍 安装 Micromamba..."
    # 确保 curl 已在 script-10 中安装
    curl -Lfo micromamba https://github.com/mamba-org/micromamba-releases/releases/latest/download/micromamba-linux-64
    {{ $sudo }}mv micromamba /usr/local/bin/
    {{ $sudo }}chmod +x /usr/local/bin/micromamba
else
    echo "  ✅ Micromamba 已安装。"
fi

# [uv] 官方脚本
if ! command -v uv &> /dev/null; then
    echo "🚀 安装 uv..."
    curl -LsSf https://astral.sh/uv/install.sh | UV_NO_MODIFY_PATH=1 sh
else
    echo "  ✅ uv 已安装。"
fi

{{- else -}}
echo "  ⏭️  Headless 模式，跳过 Micromamba/uv 安装。"
{{- end }}

# 3. [fnm] (Fast Node Manager) 官方一键安装
# 无论是否是 Headless 环境，个人开发机都需要 Node 环境
if ! command -v fnm &> /dev/null; then
    echo "🚀 安装 fnm (Fast Node Manager)..."
    # 注入 --skip-shell 是因为你的 dot_zshrc.tmpl 里已经手动写好了极其完美的 fnm 环境变量注入，不需要它的官方脚本去污染你的文件
    curl -fsSL https://fnm.vercel.app/install | bash -s -- --skip-shell
else
    echo "  ✅ fnm 已安装。"
fi