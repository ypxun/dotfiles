#!/bin/bash
# 监控清单变化: {{ include (joinPath .chezmoi.workingTree "packages/pkgs.txt") | sha256sum }}
set -eufo pipefail

{{ $sudo := "sudo " -}}
{{- if eq .chezmoi.username "root" -}}
    {{- $sudo = "" -}}
{{- end -}}

# 1. 读取包列表 (支持 pkgs.txt 内部的模板逻辑)
{{- $raw_pkgs := (includeTemplate (joinPath .chezmoi.workingTree "packages/pkgs.txt") . | splitList "\n") -}}
{{- $packages := list -}}

# 2. 差异化映射
# 空字符串 "" 代表由后续脚本(20)安装，或不安装
{{- $debian_map := dict 
    "fd" "fd-find" 
    "eza" ""          
    "micromamba" ""
    "uv" ""
-}}

{{- $arch_map := dict 
    "micromamba" "" 
    "uv" ""
-}}

# 3. 列表构建
{{- range $raw_pkgs -}}
    {{- $pkg := . | trim -}}
    {{- if and $pkg (not (hasPrefix "#" $pkg)) -}}
        {{- $target_pkg := $pkg -}}
        
        {{- /* 根据 OSID 进行名称转换 */ -}}
        {{- if eq $.osid "linux-debian" "linux-ubuntu" "linux-linuxmint" -}}
            {{- if hasKey $debian_map $pkg }}{{ $target_pkg = get $debian_map $pkg }}{{ end -}}
        {{- else if eq $.osid "linux-arch" -}}
            {{- if hasKey $arch_map $pkg }}{{ $target_pkg = get $arch_map $pkg }}{{ end -}}
        {{- end -}}

        {{- if ne $target_pkg "" -}}
            {{- $packages = mustAppend $packages $target_pkg -}}
        {{- end -}}
    {{- end -}}
{{- end -}}

echo "📦 [Install] 同步系统软件包 ({{ .osid }})..."

{{ if eq .osid "linux-debian" "linux-ubuntu" "linux-linuxmint" -}}
    {{ $sudo }}apt update && {{ $sudo }}apt install -y {{ $packages | join " " }}
{{ else if eq .osid "linux-arch" -}}
    {{ $sudo }}pacman -S --needed --noconfirm {{ $packages | join " " }}
{{ end -}}